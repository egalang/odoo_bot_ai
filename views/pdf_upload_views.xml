<odoo>
    <record id="view_pdf_upload_form" model="ir.ui.view">
        <field name="name">pdf.upload.form</field>
        <field name="model">pdf.uploads</field>
        <field name="arch" type="xml">
            <form string="Upload PDF">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="status" readonly="1"/>
                    </group>
                    <footer>
                        <button string="Upload" type="object" name="upload_pdf_to_api" class="btn btn-primary"/>
                        <button string="Cancel" class="btn btn-secondary" special="cancel"/>
                    </footer>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pdf_upload" model="ir.actions.act_window">
        <field name="name">Upload PDF</field>
        <field name="res_model">pdf.uploads</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
